# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.zip
!module-marketplace/*.zip
!theme-marketplace/*.zip
*.tar.gz
*.rar
# Backup dump files written to the repo root (e.g. uxwvend-scheduled-*.sql.gz).
# Keep this ANCHORED to the root so it doesn't accidentally swallow
# src/core/lib/backup.ts and similar first-party source files.
/backup*.sql.gz
/backup*.tar.gz
/backup*.zip

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated client
src/generated/

# Prisma schema is auto-merged by scripts/merge-schemas.ts from schema.core.prisma
# + module sources at predev/prebuild/postinstall time. Never commit the merged output.
prisma/schema.prisma

# Core generated files (module registry, route map, theme registry, openapi, etc.)
# Regenerated by scripts/generate-registry.ts / generate-themes.ts at every build.
src/core/generated/

# md files (block analysis/internal, keep README and docs)
CLAUDE.md
COMPETITOR_ANALYSIS.md
QUALITY_ANALYSIS.md
ROADMAP.md
!README.md
!docs/*.md

# Internal AI-assisted planning/spec artifacts — not part of the public release.
docs/superpowers/

# claude code
.claude/

# Test artifacts
*.png
!public/**/*.png
.playwright-mcp/
test-results/
playwright-report/

backups/
*.sql
*.sql.gz
.env.production
.env.staging
logs/
/uploads/

# First-party module sources are tracked — they are the source of truth
# for the ZIPs committed under module-marketplace/. See docs/CONTRIBUTING.md.

# Installed modules (runtime state — what the admin has activated on this
# machine). Fresh clones must stay empty so the "core knows nothing about
# modules" invariant holds.
src/modules/*
!src/modules/.gitkeep

# Legacy generated translation files (translation system is now DB-backed)
# messages/*.json is no longer written. messages-core/*.json is the seed source
# for the Translation table; runtime reads from DB via translation-service.ts.
messages/

# User-uploaded files (local fallback when S3 not configured)
public/uploads/*
!public/uploads/.gitkeep
