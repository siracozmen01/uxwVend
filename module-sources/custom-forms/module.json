{
  "id": "custom-forms",
  "name": "Custom Forms",
  "description": "Dynamic form builder with submissions",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "FileEdit",
  "permissions": [
    "forms.manage"
  ],
  "menu": [
    {
      "label": "Custom Forms",
      "path": "/forms",
      "icon": "FileEdit"
    },
    {
      "label": "Form Submissions",
      "path": "/form-submissions",
      "icon": "Inbox"
    }
  ],
  "routes": [
    {
      "path": "/form/[slug]",
      "component": "pages/public/[slug]/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/forms",
      "component": "pages/admin/page.tsx"
    },
    {
      "path": "/form-submissions",
      "component": "pages/admin/submissions/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/forms",
      "handler": "api/route.ts",
      "description": "List custom forms and create new ones (admin)."
    },
    {
      "path": "/forms/[slug]",
      "handler": "api/[slug]/route.ts",
      "description": "Get a form definition, submit it, or update/delete it (admin)."
    },
    {
      "path": "/forms/submissions",
      "handler": "api/submissions/route.ts",
      "description": "List form submissions (admin)."
    }
  ],
