  "contextProviders": [
    {
      "id": "CurrencyProvider",
      "component": "lib/context",
      "order": 10
    }
  ],
  "cronJobs": [
    {
      "id": "currency-rate-refresh",
      "schedule": "every-hour",
      "handler": "cron/refresh.ts"
    }
  ],
