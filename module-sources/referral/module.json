{
  "id": "referral",
  "name": "Referral System",
  "description": "Earn credits by referring new users",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "UserPlus",
  "dependencies": [
    "store"
  ],
  "permissions": [
    "referral.manage"
  ],
  "routes": [
    {
      "path": "/referral",
      "component": "pages/public/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/referral",
      "component": "pages/admin/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/referral",
      "handler": "api/route.ts",
      "description": "Get referral info for the current user and claim/create a referral."
    },
    {
      "path": "/referral/stats",
      "handler": "api/stats/route.ts",
      "description": "Get referral statistics and optionally track a referral event."
    }
  ],
