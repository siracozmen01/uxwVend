{
  "id": "staff",
  "name": "Staff",
  "description": "Staff member listing and applications",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "Users",
  "permissions": [
    "staff.manage"
  ],
  "menu": [
    {
      "label": "Staff Applications",
      "path": "/staff-applications",
      "icon": "FileText"
    },
    {
      "label": "Staff Members",
      "path": "/staff-members",
      "icon": "Users"
    }
  ],
  "routes": [
    {
      "path": "/staff",
      "component": "pages/public/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/staff-applications",
      "component": "pages/admin/applications/page.tsx"
    },
    {
      "path": "/staff-members",
      "component": "pages/admin/members/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/staff",
      "handler": "api/route.ts",
      "description": "List staff members and create new ones (admin)."
    },
    {
      "path": "/staff-applications",
      "handler": "api/applications/route.ts",
      "description": "List staff applications and submit a new application."
    },
    {
      "path": "/staff-applications/[id]",
      "handler": "api/applications/[id]/route.ts",
      "description": "Update application status or delete an application (admin)."
    },
    {
      "path": "/staff/[id]",
      "handler": "api/[id]/route.ts",
      "description": "Update or delete a single staff member (admin)."
    },
    {
      "path": "/staff/applications",
      "handler": "api/applications/route.ts",
      "description": "List staff applications and submit a new application."
    },
    {
      "path": "/staff/applications/[id]",
      "handler": "api/applications/[id]/route.ts",
      "description": "Update application status or delete an application (admin)."
    }
  ],
