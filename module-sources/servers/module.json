{
  "id": "servers",
  "name": "Game Servers",
  "description": "Game server management, RCON, and status monitoring",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "Server",
  "permissions": [
    "servers.manage"
  ],
  "menu": [
    {
      "label": "Game Servers",
      "path": "/servers",
      "icon": "Server"
    }
  ],
  "adminRoutes": [
    {
      "path": "/servers",
      "component": "pages/admin/page.tsx"
    },
    {
      "path": "/settings/rcon",
      "component": "pages/admin/settings/rcon/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/servers",
      "handler": "api/route.ts",
      "description": "List game servers and create new ones (admin)."
    },
    {
      "path": "/server-status",
      "handler": "api/status/route.ts",
      "description": "Get live status and player count for configured game servers."
    },
    {
      "path": "/rcon",
      "handler": "api/rcon/route.ts",
      "description": "Send RCON commands to a game server and list RCON-enabled servers (admin)."
    },
    {
      "path": "/servers/[id]",
      "handler": "api/[id]/route.ts",
      "description": "Update or delete a single game server (admin)."
    },
    {
      "path": "/servers/status",
      "handler": "api/status/route.ts",
      "description": "Get live status and player count for configured game servers."
    },
    {
      "path": "/servers/rcon",
      "handler": "api/rcon/route.ts",
      "description": "Send RCON commands to a game server and list RCON-enabled servers (admin)."
    }
  ],
  "settingsCards": [
    {
      "title": "RCON",
      "description": "Game server RCON settings.",
      "href": "/settings/rcon",
      "icon": "Server",
      "color": "text-orange-500"
    }
  ],
