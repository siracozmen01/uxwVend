  "description": "Admin-created HTML content pages",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "FileText",
  "routes": [
    {
      "path": "/page/[slug]",
      "component": "pages/public/[slug]/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/custom-pages",
      "component": "pages/admin/page.tsx"
    }
  ],
  "menu": [
    {
      "label": "Custom Pages",
      "path": "/custom-pages",
      "icon": "FileText"
    }
  ],
  "api": [
    {
      "path": "/custom-pages",
      "handler": "api/route.ts",
      "description": "List custom pages and create new ones (admin)."
    },
    {
      "path": "/custom-pages/[slug]",
      "handler": "api/[slug]/route.ts",
      "description": "Get, update, or delete a single custom page by slug."
    }
  ],
