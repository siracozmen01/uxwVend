// Player Profiles Module — Database Models
// These models are merged into prisma/schema.prisma by merge-schemas.ts

// @@user-relations-start
//   linkedAccounts   LinkedAccount[]    @relation("LinkedAccounts")
// @@user-relations-end

// ==================== ACCOUNT LINKING ====================

model LinkedAccount {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("LinkedAccounts", fields: [userId], references: [id])
  provider   String
  providerId String
  username   String?
  avatar     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@index([userId])
}
