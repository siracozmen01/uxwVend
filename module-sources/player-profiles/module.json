  "icon": "Users",
  "routes": [
    {
      "path": "/player/[username]",
      "component": "pages/public/[username]/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/players/[username]",
      "handler": "api/[username]/route.ts",
      "description": "Get a public player profile by username."
    },
    {
      "path": "/linked-accounts",
      "handler": "api/linked-accounts/route.ts",
      "description": "List, link, or unlink connected game accounts for the current user."
    },
    {
      "path": "/players/linked-accounts",
      "handler": "api/linked-accounts/route.ts",
      "description": "List, link, or unlink connected game accounts for the current user."
    }
  ],
