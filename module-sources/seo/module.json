{
  "id": "seo",
  "name": "SEO Manager",
  "description": "Advanced SEO management with per-page meta tags, OpenGraph, and structured data",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "Search",
  "permissions": [
    "seo.manage"
  ],
  "adminRoutes": [
    {
      "path": "/seo",
      "component": "pages/admin/page.tsx"
    },
    {
      "path": "/seo/pages",
      "component": "pages/admin/pages/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/seo/pages",
      "handler": "api/pages/route.ts",
      "description": "List per-page SEO configurations and create new ones (admin)."
    },
    {
      "path": "/seo/pages/[id]",
      "handler": "api/pages/[id]/route.ts",
      "description": "Update or delete a single SEO page config (admin)."
    },
    {
      "path": "/seo/settings",
      "handler": "api/settings/route.ts",
      "description": "Get or update global SEO settings (admin)."
    },
    {
      "path": "/seo/lookup",
      "handler": "api/lookup/route.ts",
      "description": "Look up SEO metadata for a given page path."
    }
  ],
  "menu": [
    {
      "label": "SEO Manager",
      "path": "/seo",
      "icon": "Search"
    }
  ],
  "layoutComponents": [
    {
      "id": "SeoHead",
      "component": "components/SeoHead.tsx"
    }
  ],
  "settingsCards": [
    {
      "title": "SEO Settings",
      "description": "Configure default meta tags and social sharing",
      "href": "/seo",
      "icon": "Search",
      "color": "text-teal-500"
    }
  ],
