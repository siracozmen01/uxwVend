{
  "id": "vote",
  "name": "Vote System",
  "description": "Vote-for-rewards system with configurable sites and cooldowns",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "Vote",
  "permissions": [
    "vote.manage"
  ],
  "menu": [
    {
      "label": "Vote Sites",
      "path": "/vote-sites",
      "icon": "Vote"
    }
  ],
  "routes": [
    {
      "path": "/vote",
      "component": "pages/public/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/vote-sites",
      "component": "pages/admin/sites/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/vote/sites",
      "handler": "api/sites/route.ts",
      "description": "List vote sites and create new ones (admin)."
    },
    {
      "path": "/vote/claim",
      "handler": "api/claim/route.ts",
      "description": "Claim vote rewards after voting on an external site."
    }
  ],
  "dependencies": [
    "credits"
  ],
