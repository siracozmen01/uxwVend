    {
      "label": "Changelog",
      "path": "/changelog",
      "icon": "History"
    }
  ],
  "routes": [
    {
      "path": "/changelog",
      "component": "pages/public/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/changelog",
      "component": "pages/admin/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/changelog",
      "handler": "api/route.ts",
      "description": "List changelog entries and create new ones (admin)."
    },
    {
      "path": "/changelog/[id]",
      "handler": "api/[id]/route.ts",
      "description": "Update or delete a single changelog entry (admin)."
    }
  ],
