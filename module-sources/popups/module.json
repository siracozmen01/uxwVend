  "menu": [
    {
      "label": "Popups",
      "path": "/popups",
      "icon": "Bell"
    }
  ],
  "adminRoutes": [
    {
      "path": "/popups",
      "component": "pages/admin/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/popups",
      "handler": "api/route.ts",
      "description": "List popups and create new ones (admin)."
    },
    {
      "path": "/popups/[id]",
      "handler": "api/[id]/route.ts",
      "description": "Update or delete a single popup (admin)."
    }
  ],
  "layoutComponents": [
    {
      "id": "PopupModal",
      "component": "components/PopupModal",
      "exclude": [
        "/admin/*"
      ]
    }
  ],
