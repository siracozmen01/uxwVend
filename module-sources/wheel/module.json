{
  "id": "wheel",
  "name": "Wheel of Fortune",
  "description": "Spin-to-win game with configurable prizes and cooldowns",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "Dices",
  "permissions": [
    "wheel.manage"
  ],
  "menu": [
    {
      "label": "Wheel Prizes",
      "path": "/wheel-prizes",
      "icon": "Dices"
    }
  ],
  "routes": [
    {
      "path": "/wheel",
      "component": "pages/public/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/wheel-prizes",
      "component": "pages/admin/prizes/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/wheel/prizes",
      "handler": "api/prizes/route.ts",
      "description": "List wheel prizes and create new ones (admin)."
    },
    {
      "path": "/wheel/prizes/[id]",
      "handler": "api/prizes/[id]/route.ts",
      "description": "Update or delete a single wheel prize (admin)."
    },
    {
      "path": "/wheel/spin",
      "handler": "api/spin/route.ts",
      "description": "Spin the prize wheel and award a prize to the current user."
    }
  ],
  "dependencies": [
    "credits"
  ],
