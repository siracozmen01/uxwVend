{
  "id": "trophies",
  "name": "Trophies",
  "description": "Achievement badges with rule-based auto-award engine",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "Trophy",
  "permissions": ["trophies.manage"],
  "menu": [
    {
      "label": "Trophies",
      "path": "/trophies",
      "icon": "Trophy"
    }
  ],
  "routes": [
    {
      "path": "/trophies",
      "component": "pages/public/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/trophies",
      "component": "pages/admin/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/trophies",
      "handler": "api/route.ts",
      "description": "Public list + admin create."
    },
    {
      "path": "/trophies/[id]",
      "handler": "api/[id]/route.ts",
      "description": "Admin update + delete."
    },
    {
      "path": "/me/trophies",
      "handler": "api/me/route.ts",
      "description": "Earned trophies for the current user."
    },
    {
      "path": "/admin/trophies",
      "handler": "api/admin/route.ts",
      "description": "Admin trophy list + create."
    },
    {
      "path": "/admin/trophies/[id]",
      "handler": "api/admin/[id]/route.ts",
      "description": "Admin trophy update + delete."
    },
    {
      "path": "/admin/trophies/reload",
      "handler": "api/admin/reload/route.ts",
      "description": "Re-register trophy hook listeners after a rule change."
    }
  ],
  "navLinks": [
    {
      "label": "Trophies",
      "href": "/trophies",
      "icon": "Trophy",
      "position": 60
    }
  ],
  "footerLinks": [
    {
      "label": "Trophies",
      "href": "/trophies",
      "section": "quick"
    }
  ],
  "profileTabs": [
    {
      "id": "trophies",
      "label": "Trophies",
      "component": "components/TrophiesTab",
      "order": 25
    }
  ],
  "settingsCards": [
    {
      "title": "Trophies",
      "description": "Manage achievement badges and rules",
      "href": "/trophies",
      "icon": "Award",
      "color": "text-amber-500"
    }
  ],
  "hookListeners": [
    {
      "hook": "core.boot",
      "type": "action",
      "handler": "hooks/on-core-boot.ts"
    }
  ],
  "seoRoutes": {
    "handler": "seo/sitemap.ts"
  },
  "userDataExport": [
    {
      "model": "userTrophy",
      "key": "trophies.earned",
      "column": "userId"
    }
  ],
