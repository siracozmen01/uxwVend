{
  "id": "tickets",
  "name": "Support Tickets",
  "description": "Customer support ticket system with departments and priority levels",
  "version": "1.0.0",
  "author": "uxwVend Team",
  "icon": "Ticket",
  "permissions": [
    "tickets.view",
    "tickets.manage",
    "tickets.create",
    "tickets.reply"
  ],
  "defaultConfig": {
    "allowAttachments": true,
    "maxAttachmentSize": 10485760,
    "autoCloseAfterDays": 7
  },
  "menu": [
    {
      "label": "Tickets",
      "path": "/tickets",
      "icon": "Ticket"
    },
    {
      "label": "Departments",
      "path": "/tickets/departments",
      "icon": "Building2"
    }
  ],
  "routes": [
    {
      "path": "/support",
      "component": "pages/public/tickets/page.tsx"
    },
    {
      "path": "/support/new",
      "component": "pages/public/tickets/new/page.tsx"
    },
    {
      "path": "/support/[id]",
      "component": "pages/public/tickets/[id]/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/tickets",
      "component": "pages/admin/tickets/page.tsx"
    },
    {
      "path": "/tickets/[id]",
      "component": "pages/admin/tickets/[id]/page.tsx"
    },
    {
      "path": "/tickets/departments",
      "component": "pages/admin/tickets/departments/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/tickets",
      "handler": "api/tickets/route.ts",
      "description": "List support tickets and create a new ticket."
    },
    {
      "path": "/tickets/departments",
      "handler": "api/tickets/departments/route.ts",
      "description": "List ticket departments and create new ones (admin)."
    },
    {
      "path": "/tickets/departments/[id]",
      "handler": "api/tickets/departments/[id]/route.ts",
      "description": "Update or delete a ticket department (admin)."
    },
    {
      "path": "/tickets/[id]",
      "handler": "api/tickets/[id]/route.ts",
      "description": "Get a ticket with messages, post a reply, or update its status."
    },
    {
      "path": "/support/stats",
      "handler": "api/stats/route.ts",
      "description": "Get aggregate ticket statistics for the admin dashboard."
    },
    {
      "path": "/tickets/stats",
      "handler": "api/stats/route.ts",
      "description": "Get aggregate ticket statistics for the admin dashboard."
    }
  ],
  "dashboardCards": [
    {
      "id": "tickets",
      "label": "Tickets",
      "icon": "Ticket",
      "href": "/admin/tickets",
      "color": "text-red-600",
      "statKey": "tickets",
      "labelKey": "dashboard_tickets"
    }
  ],
  "statsApi": "/support/stats",
