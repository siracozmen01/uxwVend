  "routes": [
    {
      "path": "/downloads",
      "component": "pages/public/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/downloads",
      "component": "pages/admin/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/downloads",
      "handler": "api/route.ts",
      "description": "List downloadable files and create new ones (admin)."
    },
    {
      "path": "/downloads/[id]",
      "handler": "api/[id]/route.ts",
      "description": "Get, update, or delete a single download entry."
    }
  ],
