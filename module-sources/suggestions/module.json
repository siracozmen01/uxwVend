{
  "id": "suggestions",
  "name": "Suggestions",
  "description": "Community feature suggestions with voting",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "MessageSquare",
  "permissions": [
    "suggestions.manage"
  ],
  "routes": [
    {
      "path": "/suggestions",
      "component": "pages/public/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/suggestions",
      "component": "pages/admin/page.tsx"
    }
  ],
  "menu": [
    {
      "label": "Suggestions",
      "path": "/suggestions",
      "icon": "MessageSquare"
    }
  ],
  "api": [
    {
      "path": "/suggestions",
      "handler": "api/route.ts",
      "description": "List suggestions and create a new suggestion."
    },
    {
      "path": "/suggestions/[id]/vote",
      "handler": "api/[id]/vote/route.ts",
      "description": "Vote on a suggestion."
    },
    {
      "path": "/suggestions/[id]",
      "handler": "api/[id]/route.ts",
      "description": "Update or delete a single suggestion (admin)."
    }
  ],
