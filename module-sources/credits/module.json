{
  "id": "credits",
  "name": "Credit System",
  "description": "Virtual currency wallet for users",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "Coins",
  "permissions": [
    "credits.view",
    "credits.manage"
