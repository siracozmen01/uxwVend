  "profileTabs": [
    {
      "id": "credits",
      "label": "Credits",
      "component": "components/CreditsTab.tsx",
      "order": 35
    }
  ],
  "api": [
    {
      "path": "/credits",
      "handler": "api/credits/route.ts",
      "description": "Get the current user credit balance."
    },
    {
      "path": "/credits/purchase",
      "handler": "api/credits/purchase/route.ts",
      "description": "Purchase credits via the configured payment gateway."
    }
  ],
  "hookListeners": [
    {
      "hook": "referral.referral.used",
      "type": "action",
      "handler": "hooks/on-referral-used.ts"
    }
  ],
