// Notifications Module — Database Models
// These models are merged into prisma/schema.prisma by merge-schemas.ts

// @@user-relations-start
//   notifications    Notification[]     @relation("Notifications")
// @@user-relations-end

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("Notifications", fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  href      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}
