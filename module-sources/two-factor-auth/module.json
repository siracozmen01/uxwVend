{
  "id": "two-factor-auth",
  "name": "Two-Factor Authentication",
  "description": "TOTP-based 2FA with backup codes for enhanced account security",
  "version": "1.0.0",
  "author": "uxwVend",
  "icon": "Shield",
  "api": [
    {
      "path": "/auth/two-factor/setup",
      "handler": "api/setup/route.ts",
      "description": "Begin 2FA setup and return a TOTP secret and QR code."
    },
    {
      "path": "/auth/two-factor/verify",
      "handler": "api/verify/route.ts",
      "description": "Verify a 2FA TOTP code to complete setup or login."
    },
    {
      "path": "/auth/two-factor/disable",
      "handler": "api/disable/route.ts",
      "description": "Disable 2FA for the current user after password confirmation."
    },
    {
      "path": "/auth/two-factor/status",
      "handler": "api/status/route.ts",
      "description": "Get 2FA status for the current user."
    },
    {
      "path": "/auth/two-factor/regenerate-codes",
      "handler": "api/regenerate-codes/route.ts",
      "description": "Regenerate 2FA backup recovery codes."
    },
    {
      "path": "/auth/verify",
      "handler": "api/verify/route.ts",
      "description": "Verify a 2FA TOTP code to complete setup or login."
    },
    {
      "path": "/auth/setup",
      "handler": "api/setup/route.ts",
      "description": "Begin 2FA setup and return a TOTP secret and QR code."
    },
    {
      "path": "/auth/disable",
      "handler": "api/disable/route.ts",
      "description": "Disable 2FA for the current user after password confirmation."
    }
  ],
  "profileTabs": [
    {
      "id": "ProfileSecurityTab",
      "label": "Security",
      "component": "components/ProfileSecurityTab",
      "order": 50
    }
  ],
