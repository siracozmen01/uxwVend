{
  "id": "help-center",
  "name": "Help Center",
  "description": "Knowledge base with categories and searchable articles",
  "version": "1.0.0",
  "author": "uxwVend Team",
  "icon": "HelpCircle",
  "permissions": [
    "help.view",
    "help.manage"
  ],
  "defaultConfig": {
    "enableSearch": true,
    "showViewCount": true,
    "enableFeedback": true
  },
  "menu": [
    {
      "label": "Help Center",
      "path": "/help",
      "icon": "HelpCircle"
    }
  ],
  "routes": [
    {
      "path": "/help",
      "component": "pages/public/help/page.tsx"
    },
    {
      "path": "/help/[slug]",
      "component": "pages/public/help/[slug]/page.tsx"
    },
    {
      "path": "/help/category/[slug]",
      "component": "pages/public/help/category/[slug]/page.tsx"
    }
  ],
  "adminRoutes": [
    {
      "path": "/help",
      "component": "pages/admin/help/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/help/articles",
      "handler": "api/help/articles/route.ts",
      "description": "List help center articles and create new ones (admin)."
    },
    {
      "path": "/help/articles/[slug]",
      "handler": "api/help/articles/[slug]/route.ts",
      "description": "Get a help article by slug or update/delete it (admin)."
    },
    {
      "path": "/help/categories",
      "handler": "api/help/categories/route.ts",
      "description": "List help center categories and create new ones (admin)."
    }
  ],
