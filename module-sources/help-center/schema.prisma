// Help Center Module — Database Models
// These models are merged into prisma/schema.prisma by merge-schemas.ts

// ==================== HELP CENTER MODULE ====================

model HelpCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  image       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles HelpArticle[]

  @@index([slug])
}

model HelpArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  views       Int      @default(0)
  helpful     Int      @default(0)
  notHelpful  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   HelpCategory @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([categoryId])
}
