    {
      "label": "Announcements",
      "path": "/announcements",
      "icon": "Megaphone"
    }
  ],
  "adminRoutes": [
    {
      "path": "/announcements",
      "component": "pages/admin/page.tsx"
    }
  ],
  "api": [
    {
      "path": "/announcements",
      "handler": "api/route.ts",
      "description": "List public announcements and create new ones (admin)."
    },
    {
      "path": "/announcements/[id]",
      "handler": "api/[id]/route.ts",
      "description": "Update or delete a single announcement (admin)."
    }
  ],
  "layoutComponents": [
    {
      "id": "AnnouncementBanner",
      "component": "components/AnnouncementBanner",
      "exclude": [
        "/admin/*"
      ]
    }
  ],
