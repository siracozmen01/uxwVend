// Core Prisma Schema — base models only
// Module models are merged from module-sources/*/schema.prisma
// DO NOT edit prisma/schema.prisma directly — it is auto-generated by merge-schemas.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== CORE MODELS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String?
  avatar        String?
  locale        String    @default("en")
  currency      String    @default("USD")
  emailVerified DateTime?
  isBanned         Boolean   @default(false)
  banReason        String?
  bannedAt         DateTime?
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role   Role?   @relation(fields: [roleId], references: [id])
  roleId String?

  accounts Account[]
  sessions Session[]

  // Core relations
  activityLogs     ActivityLog[]      @relation("ActivityLogs")
  apiKeys          ApiKey[]           @relation("ApiKeys")
  mediaItems       MediaItem[]
  revisions        Revision[]         @relation("RevisionAuthor")
  activityFeed     ActivityFeedItem[] @relation("ActivityActor")
  trophies         UserTrophy[]       @relation("UserTrophies")
  warnings         UserWarning[]      @relation("UserWarnings")
  warningsIssued   UserWarning[]      @relation("WarningIssuer")
  notifPrefs       NotificationPreference[] @relation("UserNotifPrefs")
  conversations    ConversationParticipant[] @relation("ConversationMember")
  messages         Message[]          @relation("MessageAuthor")
  loginSessions    UserSession[]      @relation("UserSessions")

  // Module relations are injected here by merge-schemas.ts
  // @@MODULE_RELATIONS

  @@index([email])
  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  displayName String
  color       String?
  priority    Int          @default(0)
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  permissions Permission[]
  users       User[]

  @@index([name])
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  module      String

  roles Role[]

  @@index([name])
  @@index([module])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  module    String   @default("core")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([module])
}

model Translation {
  id        String   @id @default(cuid())
  locale    String
  namespace String
  key       String
  value     String   @db.Text
  module    String   @default("core")
  isCustom  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locale, namespace, key, module])
  @@index([locale])
  @@index([module])
  @@index([locale, namespace])
}

model ModuleConfig {
  id        String   @id
  name      String
  enabled   Boolean  @default(true)
  config    Json     @default("{}")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tracks every module install (or update) event — used to compute the
// cumulative downloads counter displayed in the marketplace.
model ModuleInstallEvent {
  id            String   @id @default(cuid())
  moduleId      String
  version       String
  installedById String?
  createdAt     DateTime @default(now())

  @@index([moduleId])
}

// Per-user module ratings (1-5) with optional review text. The unique
// constraint enforces one rating per (module, user) — subsequent writes
// upsert the existing row.
model ModuleRating {
  id        String   @id @default(cuid())
  moduleId  String
  userId    String
  rating    Int
  review    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, userId])
  @@index([moduleId])
}

// Central media library. Every file uploaded via /api/v1/upload is recorded
// here so it can be browsed, searched, reused, and deleted from one place.
model MediaItem {
  id         String   @id @default(cuid())
  filename   String   // Original filename
  url        String   // Public URL (local or S3)
  storagePath String  // Storage path/key for delete
  mimeType   String
  size       Int      // Bytes
  width      Int?     // For images
  height     Int?
  alt        String?  // Accessibility / SEO
  uploadedById String?
  uploadedBy User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([uploadedById])
  @@index([mimeType])
  @@index([createdAt])
}

// Generic content revision history. Modules call recordRevision() before
// updates/deletes to snapshot the previous state. The (resource, resourceId)
// pair identifies the entity; data holds the JSON snapshot.
model Revision {
  id          String   @id @default(cuid())
  resource    String   // e.g. "blog.article", "store.product"
  resourceId  String   // entity primary key
  data        Json     // serialized snapshot before the change
  action      String   // "update" | "delete"
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull, name: "RevisionAuthor")
  createdAt   DateTime @default(now())

  @@index([resource, resourceId])
  @@index([authorId])
  @@index([createdAt])
}

// User warnings issued by moderators. Configurable point values; when
// a user accumulates enough points, automatic actions can fire (mute,
// ban, etc.) via hook listeners.
model UserWarning {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserWarnings")
  issuedById  String?
  issuedBy    User?    @relation(fields: [issuedById], references: [id], onDelete: SetNull, name: "WarningIssuer")
  reason      String
  points      Int      @default(1)
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([issuedById])
  @@index([isActive, expiresAt])
}

// User trophies / badges. Defined by admins, awarded by hook listeners
// or manually. Shown on public profile pages.
model Trophy {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?  // Lucide icon name
  color       String?  // Tailwind color class or hex
  points      Int      @default(0)
  // Legacy string form kept for backwards compatibility. Format:
  // "<event>:<count>" e.g. "blog.article.created:10". Prefer the
  // structured rule* columns below, which power the DB-driven engine.
  awardOn     String?
  // Structured auto-award rule. `ruleType` leaves room for non-count
  // strategies later (e.g. "streak", "sum"); today only "event-count"
  // is implemented. `ruleEvent` is the hook name to listen to,
  // `ruleThreshold` is how many matching ActivityFeedItem rows the
  // user must have before the trophy is awarded.
  ruleType      String?  @default("event-count")
  ruleEvent     String?
  ruleThreshold Int?     @default(1)
  isActive      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserTrophy[]
}

model UserTrophy {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserTrophies")
  trophyId  String
  trophy    Trophy   @relation(fields: [trophyId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, trophyId])
  @@index([userId])
  @@index([trophyId])
}

// Cross-module unified activity feed.
// Modules emit hooks (e.g. blog.article.created) and a core listener
// records them here as feed items. Rendered on public profile pages
// and a sitewide /activity stream.
model ActivityFeedItem {
  id         String   @id @default(cuid())
  type       String   // e.g. "blog.article.created", "store.order.completed"
  actorId    String?  // user who triggered it
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: Cascade, name: "ActivityActor")
  title      String   // human-readable headline
  body       String?  // optional excerpt / preview
  href       String?  // link to the entity
  icon       String?  // Lucide icon name for the feed UI
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([type])
  @@index([createdAt])
  @@index([isPublic, createdAt])
}

// Granular per-resource permission grants on top of role-based defaults.
// See docs in core/lib/permissions.ts for resolution order.
model ResourcePermission {
  id            String   @id @default(cuid())
  resource      String   // e.g. "blog.article"
  resourceId    String?  // null = applies to all entities of that resource
  action        String   // "view" | "create" | "edit" | "delete" | "*"
  principalType String   // "role" | "user"
  principalId   String   // role.id or user.id
  allow         Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@unique([resource, resourceId, action, principalType, principalId])
  @@index([resource, action])
  @@index([principalType, principalId])
}

// Active user sessions. Tracks per-device login info so users can review
// and revoke other sessions from the profile page.
model UserSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserSessions")
  tokenId      String   @unique
  deviceInfo   String?
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)

  @@index([userId])
  @@index([tokenId])
  @@index([expiresAt])
}

// User-to-user direct messaging.
// Conversation has 2+ participants and many messages.
model Conversation {
  id            String   @id @default(cuid())
  title         String?  // optional, usually omitted for 1:1 chats
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime?

  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade, name: "ConversationMember")
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade, name: "MessageAuthor")
  body           String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([authorId])
}

// Per-user notification preferences. Each row represents one user's
// choice for one event type + channel. Missing rows default to enabled.
model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserNotifPrefs")
  eventType String
  channel   String   // "email" | "inapp"
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([userId, eventType, channel])
  @@index([userId])
}

// Email broadcast — admin sends a single message to many users.
// Status: draft → queued → sending → sent (or failed)
model EmailBroadcast {
  id            String   @id @default(cuid())
  subject       String
  body          String   @db.Text
  status        String   @default("draft") // draft|queued|sending|sent|failed
  filter        Json     @default("{}")    // { roleIds?, userIds?, all? }
  createdById   String?
  totalCount    Int      @default(0)
  sentCount     Int      @default(0)
  failedCount   Int      @default(0)
  lastError     String?
  scheduledFor  DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([scheduledFor])
}

// Tracks per-cron-job last-run timestamps. The scheduler reads/writes
// this on every tick to decide which jobs are due.
model CronRun {
  jobKey      String   @id   // "<moduleId>:<jobId>" or "core:<jobId>"
  lastRunAt   DateTime
  lastStatus  String?  // "ok" | "error"
  lastError   String?
  lastRunMs   Int?
  nextRunAt   DateTime?

  @@index([nextRunAt])
}

// Tracks which per-module SQL migrations have been applied to the DB.
// Replaces the old `prisma db push` workflow with a forward-only
// versioned migration system. See docs/MIGRATIONS.md.
model ModuleMigration {
  id            String   @id @default(cuid())
  moduleId      String
  migrationName String
  checksum      String
  appliedAt     DateTime @default(now())
  executionMs   Int?

  @@unique([moduleId, migrationName])
  @@index([moduleId])
}

model ThemeConfig {
  id        String   @id
  name      String
  active    Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExchangeRate {
  id        String   @id @default(cuid())
  currency  String   @unique
  rate      Decimal  @db.Decimal(10, 6)
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyHash     String
  keyPrefix   String
  userId      String
  user        User     @relation("ApiKeys", fields: [userId], references: [id], onDelete: Cascade)
  permissions String[] @default([])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([keyPrefix])
  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation("ActivityLogs", fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
  @@index([createdAt])
}

// IP allowlist / blocklist. Supports single IPv4 addresses and
// IPv4 CIDR ranges (e.g. "192.168.1.0/24"). Scope limits where the
// block applies: "all" = entire site, "admin" = only /{locale}/admin
// and admin APIs, "api" = only /api/* endpoints. Optional expiresAt
// makes the block temporary; null = permanent.
model IpBlock {
  id          String    @id @default(cuid())
  ip          String    @unique
  scope       String    @default("all")
  reason      String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  createdById String?

  @@index([ip])
  @@index([scope])
  @@index([expiresAt])
}

// Outbound email queue. Synchronous SMTP calls would block request
// handling and fail silently on transient errors; instead most callers
// enqueue via queueEmail() and a core cron (processEmailQueue) drains
// the queue every 5 minutes with exponential backoff.
//
// status flow:  pending → sending → sent
//                       \→ pending (retry, attempts < 3)
//                       \→ failed  (attempts >= 3)
model EmailJob {
  id          String    @id @default(cuid())
  to          String
  subject     String
  body        String
  html        String?
  status      String    @default("pending") // pending | sending | sent | failed
  attempts    Int       @default(0)
  lastError   String?
  scheduledAt DateTime  @default(now())
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([createdAt])
}
