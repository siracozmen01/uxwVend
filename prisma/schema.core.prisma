// Core Prisma Schema — base models only
// Module models are merged from module-sources/*/schema.prisma
// DO NOT edit prisma/schema.prisma directly — it is auto-generated by merge-schemas.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== CORE MODELS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String?
  avatar        String?
  locale        String    @default("en")
  currency      String    @default("USD")
  emailVerified DateTime?
  isBanned         Boolean   @default(false)
  banReason        String?
  bannedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role   Role?   @relation(fields: [roleId], references: [id])
  roleId String?

  accounts Account[]
  sessions Session[]

  // Core relations
  activityLogs     ActivityLog[]      @relation("ActivityLogs")
  apiKeys          ApiKey[]           @relation("ApiKeys")
  mediaItems       MediaItem[]

  // Module relations are injected here by merge-schemas.ts
  // @@MODULE_RELATIONS

  @@index([email])
  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  displayName String
  color       String?
  priority    Int          @default(0)
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  permissions Permission[]
  users       User[]

  @@index([name])
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  module      String

  roles Role[]

  @@index([name])
  @@index([module])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  module    String   @default("core")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([module])
}

model ModuleConfig {
  id        String   @id
  name      String
  enabled   Boolean  @default(true)
  config    Json     @default("{}")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Central media library. Every file uploaded via /api/v1/upload is recorded
// here so it can be browsed, searched, reused, and deleted from one place.
model MediaItem {
  id         String   @id @default(cuid())
  filename   String   // Original filename
  url        String   // Public URL (local or S3)
  storagePath String  // Storage path/key for delete
  mimeType   String
  size       Int      // Bytes
  width      Int?     // For images
  height     Int?
  alt        String?  // Accessibility / SEO
  uploadedById String?
  uploadedBy User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([uploadedById])
  @@index([mimeType])
  @@index([createdAt])
}

// Tracks which per-module SQL migrations have been applied to the DB.
// Replaces the old `prisma db push` workflow with a forward-only
// versioned migration system. See docs/MIGRATIONS.md.
model ModuleMigration {
  id            String   @id @default(cuid())
  moduleId      String
  migrationName String
  checksum      String
  appliedAt     DateTime @default(now())
  executionMs   Int?

  @@unique([moduleId, migrationName])
  @@index([moduleId])
}

model ThemeConfig {
  id        String   @id
  name      String
  active    Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExchangeRate {
  id        String   @id @default(cuid())
  currency  String   @unique
  rate      Decimal  @db.Decimal(10, 6)
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyHash     String
  keyPrefix   String
  userId      String
  user        User     @relation("ApiKeys", fields: [userId], references: [id], onDelete: Cascade)
  permissions String[] @default([])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([keyPrefix])
  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation("ActivityLogs", fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
  @@index([createdAt])
}
