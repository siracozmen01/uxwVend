// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CORE MODELS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String?
  avatar        String?
  locale        String    @default("en")
  currency      String    @default("USD")
  emailVerified DateTime?
  isBanned         Boolean   @default(false)
  banReason        String?
  bannedAt         DateTime?
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  backupCodes      String?
  createdAt        DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role   Role?   @relation(fields: [roleId], references: [id])
  roleId String?

  accounts Account[]
  sessions Session[]

  // Store relations
  orders Order[]
  cart   CartItem[]

  // Forum relations
  topics     ForumTopic[]
  posts      ForumPost[]
  topicLikes ForumTopicLike[]
  postLikes  ForumPostLike[]

  // Blog relations
  articles BlogArticle[]
  comments BlogComment[]

  // Ticket relations
  tickets        Ticket[]
  ticketMessages TicketMessage[]
  assignedTickets Ticket[] @relation("AssignedTickets")

  // Gift relations
  redeemedGifts GiftCode[] @relation("RedeemedGifts")

  // Credit & Vote relations
  creditBalance    Decimal            @default(0) @db.Decimal(10, 2)
  creditHistory    CreditTransaction[]
  votes            VoteLog[]

  // P2 relations
  staffProfile     StaffMember[]      @relation("StaffProfile")
  creatorCodes     CreatorCode[]      @relation("CreatorCodes")
  suggestions      Suggestion[]       @relation("Suggestions")
  suggestionVotes  SuggestionVote[]   @relation("SuggestionVotes")
  staffApplications StaffApplication[] @relation("StaffApplications")
  activityLogs     ActivityLog[]      @relation("ActivityLogs")
  wheelSpins       WheelSpin[]        @relation("WheelSpins")
  ownedProducts    OwnedProduct[]     @relation("OwnedProducts")
  chestItems       ChestItem[]        @relation("ChestItems")
  linkedAccounts   LinkedAccount[]    @relation("LinkedAccounts")
  apiKeys          ApiKey[]           @relation("ApiKeys")
  notifications    Notification[]     @relation("Notifications")

  @@index([email])
  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  displayName String
  color       String?
  priority    Int          @default(0)
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  permissions Permission[]
  users       User[]

  @@index([name])
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  module      String

  roles Role[]

  @@index([name])
  @@index([module])
}

// ==================== GAME SERVERS ====================

model GameServer {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("minecraft") // minecraft, fivem, rust, ark, csgo
  host        String
  port        Int      @default(25565)
  rconPort    Int?
  rconPassword String?
  queryPort   Int?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== API KEYS ====================

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  userId      String
  user        User     @relation("ApiKeys", fields: [userId], references: [id])
  permissions String[] @default([])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([key])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("Notifications", fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  href      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

// ==================== CHEST (Store & Redeem) ====================

model ChestItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("ChestItems", fields: [userId], references: [id])
  productId   String
  productName String
  quantity    Int      @default(1)
  isRedeemed  Boolean  @default(false)
  redeemedAt  DateTime?
  giftedToId  String?
  orderId     String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

// ==================== ACCOUNT LINKING ====================

model LinkedAccount {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("LinkedAccounts", fields: [userId], references: [id])
  provider   String   // discord, steam, minecraft
  providerId String
  username   String?
  avatar     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@index([userId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  module    String   @default("core")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([module])
}

model ModuleConfig {
  id        String   @id
  name      String
  enabled   Boolean  @default(true)
  config    Json     @default("{}")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ThemeConfig {
  id        String   @id
  name      String
  active    Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExchangeRate {
  id        String   @id @default(cuid())
  currency  String   @unique
  rate      Decimal  @db.Decimal(10, 6)
  updatedAt DateTime @updatedAt
}

// ==================== STORE MODULE ====================

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  parent      Category? @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([slug])
  @@index([parentId])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  translations  Json?    // Stores multi-language data: { en: { name: "...", description: "..." } }
  description   String?  @db.Text
  shortDesc     String?
  price         Decimal  @db.Decimal(10, 2)
  comparePrice  Decimal? @db.Decimal(10, 2)
  image         String?
  images        String[] @default([])
  stock         Int?
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  type          ProductType @default(DIGITAL)
  deliveryData  Json?    // Commands, items, etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([slug])
  @@index([categoryId])
  @@index([isActive, isFeatured])
}

enum ProductType {
  DIGITAL
  PHYSICAL
  GAME_ITEM
  SUBSCRIPTION
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  status        OrderStatus @default(PENDING)
  total         Decimal     @db.Decimal(10, 2)
  subtotal      Decimal     @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  currency      String      @default("USD")
  paymentMethod String?
  paymentId     String?
  notes         String?
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items    OrderItem[]
  payments Payment[]

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(10, 2)
  name      String
  metadata  Json?

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model CartItem {
  id       String @id @default(cuid())
  quantity Int    @default(1)

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")
  status        PaymentStatus @default(PENDING)
  provider      String        // stripe, paypal, etc.
  providerId    String?       // external payment id
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([providerId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Coupon {
  id            String      @id @default(cuid())
  code          String      @unique
  description   String?
  type          CouponType  @default(PERCENTAGE)
  value         Decimal     @db.Decimal(10, 2)
  minPurchase   Decimal?    @db.Decimal(10, 2)
  maxDiscount   Decimal?    @db.Decimal(10, 2)
  usageLimit    Int?
  usageCount    Int         @default(0)
  startsAt      DateTime?
  expiresAt     DateTime?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([code])
  @@index([isActive])
}

enum CouponType {
  PERCENTAGE
  FIXED
}

model OwnedProduct {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("OwnedProducts", fields: [userId], references: [id])
  productId String
  orderId   String?
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model BulkDiscount {
  id           String   @id @default(cuid())
  name         String
  minQuantity  Int
  discountPercent Int
  productId    String?
  categoryId   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([productId])
  @@index([categoryId])
}

model GiftCode {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  value       Decimal   @db.Decimal(10, 2)
  isRedeemed  Boolean   @default(false)
  redeemedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  redeemedById String?
  redeemedBy   User?   @relation("RedeemedGifts", fields: [redeemedById], references: [id])
  createdById  String?

  @@index([code])
}

// ==================== ANNOUNCEMENTS ====================

model Announcement {
  id        String    @id @default(cuid())
  title     String
  content   String
  type      String    @default("info") // info, warning, success, error
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ==================== CUSTOM PAGES ====================

model CustomPage {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

// ==================== CREDITS ====================

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Decimal  @db.Decimal(10, 2)
  type        String   // purchase, spend, gift, refund
  description String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

// ==================== VOTE ====================

model VoteSite {
  id        String    @id @default(cuid())
  name      String
  url       String
  reward    Int       @default(0)
  icon      String?
  isActive  Boolean   @default(true)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  votes     VoteLog[]
}

model VoteLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  voteSiteId String
  voteSite   VoteSite @relation(fields: [voteSiteId], references: [id])
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([voteSiteId])
}

// ==================== CHANGELOG ====================

model ChangelogEntry {
  id        String   @id @default(cuid())
  version   String
  title     String
  content   String   @db.Text
  type      String   @default("update") // update, feature, fix, breaking
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ==================== STAFF PAGE ====================

model StaffMember {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation("StaffProfile", fields: [userId], references: [id])
  name      String
  role      String
  avatar    String?
  order     Int     @default(0)
  isActive  Boolean @default(true)
}

// ==================== CREATOR CODES ====================

model CreatorCode {
  id              String   @id @default(cuid())
  code            String   @unique
  creatorId       String
  creator         User     @relation("CreatorCodes", fields: [creatorId], references: [id])
  discountPercent Int      @default(5)
  commissionPercent Int    @default(5)
  usageCount      Int      @default(0)
  totalRevenue    Decimal  @default(0) @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([code])
  @@index([creatorId])
}

// ==================== SUGGESTIONS ====================

model Suggestion {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  status    String   @default("open") // open, under_review, accepted, rejected, completed
  upvotes   Int      @default(0)
  authorId  String
  author    User     @relation("Suggestions", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes SuggestionVote[]

  @@index([status])
  @@index([authorId])
}

model SuggestionVote {
  id           String     @id @default(cuid())
  suggestionId String
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("SuggestionVotes", fields: [userId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([suggestionId, userId])
}

// ==================== CUSTOM FORMS ====================

model CustomForm {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  fields      Json     // Array of field definitions [{name, type, label, required, options}]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions CustomFormSubmission[]
  @@index([slug])
}

model CustomFormSubmission {
  id        String     @id @default(cuid())
  formId    String
  form      CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId    String?
  data      Json       // Submitted field values
  status    String     @default("new") // new, reviewed, archived
  createdAt DateTime   @default(now())

  @@index([formId])
}

// ==================== SLIDER ====================

model SliderItem {
  id        String   @id @default(cuid())
  title     String?
  subtitle  String?
  image     String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ==================== WEBHOOK LOGS ====================

model WebhookLog {
  id        String   @id @default(cuid())
  event     String
  url       String
  status    Int?
  response  String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}

// ==================== PRODUCT VARIABLES ====================

model ProductVariable {
  id          String  @id @default(cuid())
  productId   String
  name        String  // e.g. "minecraft_nick"
  label       String  // e.g. "Minecraft Username"
  type        String  @default("text") // text, select, number
  required    Boolean @default(true)
  placeholder String?
  options     String? // comma-separated for select type

  @@index([productId])
}

model ProductCommand {
  id        String @id @default(cuid())
  productId String
  command   String // e.g. "give {player} diamond 64"
  order     Int    @default(0)

  @@index([productId])
}

// ==================== POPUP ====================

model Popup {
  id        String    @id @default(cuid())
  title     String
  content   String?
  image     String?
  link      String?
  linkText  String?
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
}

// ==================== STAFF APPLICATIONS ====================

model StaffApplication {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("StaffApplications", fields: [userId], references: [id])
  position  String
  content   String   @db.Text
  status    String   @default("pending") // pending, accepted, rejected
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ==================== ACTIVITY LOG ====================

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation("ActivityLogs", fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ==================== DOWNLOAD CENTER ====================

model Download {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileName    String
  fileUrl     String
  fileSize    Int?
  downloads   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== PUNISHMENTS ====================

model Punishment {
  id         String    @id @default(cuid())
  playerName String
  playerUuid String?
  type       String    // ban, mute, kick, warn
  reason     String?
  duration   String?   // "permanent", "7d", "30m" etc
  active     Boolean   @default(true)
  punishedBy String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  @@index([playerName])
  @@index([type])
  @@index([active])
}

// ==================== WHEEL OF FORTUNE ====================

model WheelPrize {
  id          String  @id @default(cuid())
  name        String
  type        String  // credits, coupon, nothing
  value       Int     @default(0)
  color       String  @default("#3b82f6")
  probability Int     @default(10) // weight 1-100
  isActive    Boolean @default(true)
  order       Int     @default(0)
}

model WheelSpin {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("WheelSpins", fields: [userId], references: [id])
  prizeId   String?
  prizeName String
  prizeValue Int     @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ==================== FORUM MODULE ====================

model ForumCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topics ForumTopic[]

  @@index([slug])
}

model ForumTopic {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  isPinned    Boolean  @default(false)
  isLocked    Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id])
  authorId   String
  author     User          @relation(fields: [authorId], references: [id])

  posts ForumPost[]
  likes ForumTopicLike[]

  @@index([slug])
  @@index([categoryId])
  @@index([authorId])
}

model ForumPost {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topicId  String
  topic    ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  authorId String
  author   User       @relation(fields: [authorId], references: [id])

  likes ForumPostLike[]

  @@index([topicId])
  @@index([authorId])
}

model ForumTopicLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  topicId String
  topic   ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userId  String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
}

model ForumPostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ==================== BLOG MODULE ====================

model BlogCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles BlogArticle[]

  @@index([slug])
}

model BlogArticle {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String        @db.Text
  coverImage  String?
  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?
  views       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  categoryId String?
  category   BlogCategory? @relation(fields: [categoryId], references: [id])
  authorId   String
  author     User          @relation(fields: [authorId], references: [id])

  comments BlogComment[]
  tags     BlogTag[]

  @@index([slug])
  @@index([status])
  @@index([authorId])
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

model BlogComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  isApproved Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articleId String
  article   BlogArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId  String
  author    User        @relation(fields: [authorId], references: [id])

  @@index([articleId])
  @@index([authorId])
}

model BlogTag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  articles BlogArticle[]

  @@index([slug])
}

// ==================== TICKETS MODULE ====================

model TicketDepartment {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets Ticket[]
}

model Ticket {
  id          String         @id @default(cuid())
  subject     String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  closedAt    DateTime?

  departmentId String
  department   TicketDepartment @relation(fields: [departmentId], references: [id])
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  assignedToId String?
  assignedTo   User?            @relation("AssignedTickets", fields: [assignedToId], references: [id])

  messages TicketMessage[]

  @@index([userId])
  @@index([departmentId])
  @@index([status])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_REPLY
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TicketMessage {
  id          String   @id @default(cuid())
  content     String   @db.Text
  isStaffReply Boolean @default(false)
  attachments String[] @default([])
  createdAt   DateTime @default(now())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

model CannedResponse {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== HELP CENTER MODULE ====================

model HelpCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles HelpArticle[]

  @@index([slug])
}

model HelpArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  views       Int      @default(0)
  helpful     Int      @default(0)
  notHelpful  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   HelpCategory @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([categoryId])
}
