// Core Prisma Schema — base models only
// Module models are merged from module-sources/*/schema.prisma
// DO NOT edit prisma/schema.prisma directly — it is auto-generated by merge-schemas.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== CORE MODELS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String?
  avatar        String?
  locale        String    @default("en")
  currency      String    @default("USD")
  emailVerified DateTime?
  isBanned         Boolean   @default(false)
  banReason        String?
  bannedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role   Role?   @relation(fields: [roleId], references: [id])
  roleId String?

  accounts Account[]
  sessions Session[]

  // Core relations
  activityLogs     ActivityLog[]      @relation("ActivityLogs")
  apiKeys          ApiKey[]           @relation("ApiKeys")
  mediaItems       MediaItem[]
  revisions        Revision[]         @relation("RevisionAuthor")

  // Module relations are injected here by merge-schemas.ts

  // blog module
  articles BlogArticle[]
  comments BlogComment[]

  // forum module
  topics     ForumTopic[]
  posts      ForumPost[]
  topicLikes ForumTopicLike[]
  postLikes  ForumPostLike[]

  // in-app-notifications module
  notifications    Notification[]     @relation("Notifications")

  // player-profiles module
  linkedAccounts   LinkedAccount[]    @relation("LinkedAccounts")

  // referral module
  referralCode     String?   @unique
  referredBy       String?
  referrals        Referral[] @relation("ReferrerReferrals")
  referredReferral Referral?  @relation("ReferredReferral")

  // staff module
  staffProfile     StaffMember[]      @relation("StaffProfile")
  staffApplications StaffApplication[] @relation("StaffApplications")

  // store module
  orders Order[]
  cart   CartItem[]
  redeemedGifts GiftCode[] @relation("RedeemedGifts")
  creditBalance    Decimal            @default(0) @db.Decimal(10, 2)
  creditHistory    CreditTransaction[]
  creatorCodes     CreatorCode[]      @relation("CreatorCodes")
  ownedProducts    OwnedProduct[]     @relation("OwnedProducts")
  chestItems       ChestItem[]        @relation("ChestItems")
  stripeCustomerId String?
  subscriptions    Subscription[]

  // suggestions module
  suggestions      Suggestion[]       @relation("Suggestions")
  suggestionVotes  SuggestionVote[]   @relation("SuggestionVotes")

  // tickets module
  tickets        Ticket[]
  ticketMessages TicketMessage[]
  assignedTickets Ticket[] @relation("AssignedTickets")

  // two-factor-auth module
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  backupCodes      String?

  // vote module
  votes            VoteLog[]

  // wheel module
  wheelSpins       WheelSpin[]        @relation("WheelSpins")


  @@index([email])
  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  displayName String
  color       String?
  priority    Int          @default(0)
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  permissions Permission[]
  users       User[]

  @@index([name])
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  module      String

  roles Role[]

  @@index([name])
  @@index([module])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  module    String   @default("core")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([module])
}

model ModuleConfig {
  id        String   @id
  name      String
  enabled   Boolean  @default(true)
  config    Json     @default("{}")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Central media library. Every file uploaded via /api/v1/upload is recorded
// here so it can be browsed, searched, reused, and deleted from one place.
model MediaItem {
  id         String   @id @default(cuid())
  filename   String   // Original filename
  url        String   // Public URL (local or S3)
  storagePath String  // Storage path/key for delete
  mimeType   String
  size       Int      // Bytes
  width      Int?     // For images
  height     Int?
  alt        String?  // Accessibility / SEO
  uploadedById String?
  uploadedBy User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([uploadedById])
  @@index([mimeType])
  @@index([createdAt])
}

// Generic content revision history. Modules call recordRevision() before
// updates/deletes to snapshot the previous state. The (resource, resourceId)
// pair identifies the entity; data holds the JSON snapshot.
model Revision {
  id          String   @id @default(cuid())
  resource    String   // e.g. "blog.article", "store.product"
  resourceId  String   // entity primary key
  data        Json     // serialized snapshot before the change
  action      String   // "update" | "delete"
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull, name: "RevisionAuthor")
  createdAt   DateTime @default(now())

  @@index([resource, resourceId])
  @@index([authorId])
  @@index([createdAt])
}

// Granular per-resource permission grants on top of role-based defaults.
// See docs in core/lib/permissions.ts for resolution order.
model ResourcePermission {
  id            String   @id @default(cuid())
  resource      String   // e.g. "blog.article"
  resourceId    String?  // null = applies to all entities of that resource
  action        String   // "view" | "create" | "edit" | "delete" | "*"
  principalType String   // "role" | "user"
  principalId   String   // role.id or user.id
  allow         Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@unique([resource, resourceId, action, principalType, principalId])
  @@index([resource, action])
  @@index([principalType, principalId])
}

// Tracks which per-module SQL migrations have been applied to the DB.
// Replaces the old `prisma db push` workflow with a forward-only
// versioned migration system. See docs/MIGRATIONS.md.
model ModuleMigration {
  id            String   @id @default(cuid())
  moduleId      String
  migrationName String
  checksum      String
  appliedAt     DateTime @default(now())
  executionMs   Int?

  @@unique([moduleId, migrationName])
  @@index([moduleId])
}

model ThemeConfig {
  id        String   @id
  name      String
  active    Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExchangeRate {
  id        String   @id @default(cuid())
  currency  String   @unique
  rate      Decimal  @db.Decimal(10, 6)
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyHash     String
  keyPrefix   String
  userId      String
  user        User     @relation("ApiKeys", fields: [userId], references: [id], onDelete: Cascade)
  permissions String[] @default([])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([keyPrefix])
  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation("ActivityLogs", fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
  @@index([createdAt])
}


// ==================== MODULE: announcements ====================

model Announcement {
  id           String    @id @default(cuid())
  title        String
  content      String
  type         String    @default("info")
  isActive     Boolean   @default(true)
  dismissible  Boolean   @default(true)
  includePages String?
  excludePages String?
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ==================== MODULE: blog ====================

model BlogCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles BlogArticle[]

  @@index([slug])
}

model BlogArticle {
  id          String        @id @default(cuid())
  number      Int           @unique @default(autoincrement())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String        @db.Text
  coverImage  String?
  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?
  views       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  categoryId String?
  category   BlogCategory? @relation(fields: [categoryId], references: [id])
  authorId   String
  author     User          @relation(fields: [authorId], references: [id])

  comments BlogComment[]
  tags     BlogTag[]

  @@index([slug])
  @@index([status])
  @@index([authorId])
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

model BlogComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  isApproved Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articleId String
  article   BlogArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId  String
  author    User        @relation(fields: [authorId], references: [id])

  @@index([articleId])
  @@index([authorId])
}

model BlogTag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  articles BlogArticle[]

  @@index([slug])
}

// ==================== MODULE: changelog ====================

model ChangelogEntry {
  id        String   @id @default(cuid())
  version   String
  title     String
  content   String   @db.Text
  type      String   @default("update")
  color     String?  @default("#3b82f6")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ==================== MODULE: custom-forms ====================

model CustomForm {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  fields      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions CustomFormSubmission[]
  @@index([slug])
}

model CustomFormSubmission {
  id        String     @id @default(cuid())
  formId    String
  form      CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId    String?
  data      Json
  status    String     @default("new")
  createdAt DateTime   @default(now())

  @@index([formId])
}

// ==================== MODULE: custom-pages ====================

model CustomPage {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

// ==================== MODULE: downloads ====================

model Download {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileName    String
  fileUrl     String
  fileSize    Int?
  downloads   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== MODULE: forum ====================

model ForumCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topics ForumTopic[]

  @@index([slug])
}

model ForumTopic {
  id          String   @id @default(cuid())
  number      Int      @unique @default(autoincrement())
  title       String
  slug        String   @unique
  content     String   @db.Text
  isPinned    Boolean  @default(false)
  isLocked    Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id])
  authorId   String
  author     User          @relation(fields: [authorId], references: [id])

  posts ForumPost[]
  likes ForumTopicLike[]

  @@index([slug])
  @@index([categoryId])
  @@index([authorId])
}

model ForumPost {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topicId  String
  topic    ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  authorId String
  author   User       @relation(fields: [authorId], references: [id])

  likes ForumPostLike[]

  @@index([topicId])
  @@index([authorId])
}

model ForumTopicLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  topicId String
  topic   ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userId  String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
}

model ForumPostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ==================== MODULE: help-center ====================

model HelpCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  image       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles HelpArticle[]

  @@index([slug])
}

model HelpArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  views       Int      @default(0)
  helpful     Int      @default(0)
  notHelpful  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   HelpCategory @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([categoryId])
}

// ==================== MODULE: in-app-notifications ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("Notifications", fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  href      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

// ==================== MODULE: player-profiles ====================

model LinkedAccount {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("LinkedAccounts", fields: [userId], references: [id])
  provider   String
  providerId String
  username   String?
  avatar     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@index([userId])
}

// ==================== MODULE: popups ====================

model Popup {
  id        String    @id @default(cuid())
  title     String
  content   String?
  image     String?
  link      String?
  linkText  String?
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
}

// ==================== MODULE: punishments ====================

model Punishment {
  id         String    @id @default(cuid())
  playerName String
  playerUuid String?
  type       String
  reason     String?
  duration   String?
  active     Boolean   @default(true)
  punishedBy String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  @@index([playerName])
  @@index([type])
  @@index([active])
}

// ==================== MODULE: referral ====================

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referrer     User     @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredId   String   @unique
  referred     User     @relation("ReferredReferral", fields: [referredId], references: [id])
  rewardAmount Decimal  @default(0) @db.Decimal(10, 2)
  status       String   @default("pending") // pending, completed, rewarded
  createdAt    DateTime @default(now())

  @@index([referrerId])
}

// ==================== MODULE: seo ====================

model SeoPage {
  id              String   @id @default(cuid())
  path            String   @unique
  metaTitle       String?
  metaDescription String?  @db.Text
  ogTitle         String?
  ogDescription   String?  @db.Text
  ogImage         String?
  keywords        String?
  canonical       String?
  noIndex         Boolean  @default(false)
  noFollow        Boolean  @default(false)
  structuredData  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([path])
}

// ==================== MODULE: servers ====================

model GameServer {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("minecraft")
  host        String
  port        Int      @default(25565)
  rconPort    Int?
  rconPassword String?
  queryPort   Int?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== MODULE: slider ====================

model SliderItem {
  id        String   @id @default(cuid())
  title     String?
  subtitle  String?
  image     String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ==================== MODULE: staff ====================

model StaffMember {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation("StaffProfile", fields: [userId], references: [id])
  name      String
  role      String
  avatar    String?
  order     Int     @default(0)
  isActive  Boolean @default(true)
}

// ==================== STAFF APPLICATIONS ====================

model StaffApplication {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("StaffApplications", fields: [userId], references: [id])
  position  String
  content   String   @db.Text
  status    String   @default("pending")
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ==================== MODULE: store ====================

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  parent      Category? @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([slug])
  @@index([parentId])
}

model Product {
  id            String   @id @default(cuid())
  number        Int      @unique @default(autoincrement())
  name          String
  slug          String   @unique
  translations  Json?
  description   String?  @db.Text
  shortDesc     String?
  price         Decimal  @db.Decimal(10, 2)
  comparePrice  Decimal? @db.Decimal(10, 2)
  image         String?
  images        String[] @default([])
  stock         Int?
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  type          ProductType @default(DIGITAL)
  deliveryData  Json?
  subscriptionInterval      String?
  subscriptionIntervalCount Int?      @default(1)
  stripePriceId             String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  orderItems OrderItem[]
  cartItems  CartItem[]
  subscriptions Subscription[]

  @@index([slug])
  @@index([categoryId])
  @@index([isActive, isFeatured])
}

enum ProductType {
  DIGITAL
  PHYSICAL
  GAME_ITEM
  SUBSCRIPTION
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  status        OrderStatus @default(PENDING)
  total         Decimal     @db.Decimal(10, 2)
  subtotal      Decimal     @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  tax           Decimal     @default(0) @db.Decimal(10, 2)
  currency      String      @default("USD")
  paymentMethod String?
  paymentId     String?
  notes         String?
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items    OrderItem[]
  payments Payment[]

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(10, 2)
  name      String
  metadata  Json?

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model CartItem {
  id       String @id @default(cuid())
  quantity Int    @default(1)

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")
  status        PaymentStatus @default(PENDING)
  provider      String
  providerId    String?
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([providerId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Coupon {
  id            String      @id @default(cuid())
  code          String      @unique
  description   String?
  type          CouponType  @default(PERCENTAGE)
  value         Decimal     @db.Decimal(10, 2)
  minPurchase   Decimal?    @db.Decimal(10, 2)
  maxDiscount   Decimal?    @db.Decimal(10, 2)
  usageLimit    Int?
  usageCount    Int         @default(0)
  startsAt      DateTime?
  expiresAt     DateTime?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([code])
  @@index([isActive])
}

enum CouponType {
  PERCENTAGE
  FIXED
}

model OwnedProduct {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("OwnedProducts", fields: [userId], references: [id])
  productId String
  orderId   String?
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model BulkDiscount {
  id           String   @id @default(cuid())
  name         String
  minQuantity  Int
  discountPercent Int
  productId    String?
  categoryId   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([productId])
  @@index([categoryId])
}

model GiftCode {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  value       Decimal   @db.Decimal(10, 2)
  isRedeemed  Boolean   @default(false)
  redeemedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  redeemedById String?
  redeemedBy   User?   @relation("RedeemedGifts", fields: [redeemedById], references: [id])
  createdById  String?

  @@index([code])
}

model ProductVariable {
  id          String  @id @default(cuid())
  productId   String
  name        String
  label       String
  type        String  @default("text")
  required    Boolean @default(true)
  placeholder String?
  options     String?

  @@index([productId])
}

model ProductCommand {
  id        String  @id @default(cuid())
  productId String
  command   String
  serverId  String?
  order     Int     @default(0)

  @@index([productId])
}

model ChestItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("ChestItems", fields: [userId], references: [id])
  productId   String
  productName String
  quantity    Int      @default(1)
  isRedeemed  Boolean  @default(false)
  redeemedAt  DateTime?
  giftedToId  String?
  orderId     String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Decimal  @db.Decimal(10, 2)
  type        String
  description String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model CreatorCode {
  id              String   @id @default(cuid())
  code            String   @unique
  creatorId       String
  creator         User     @relation("CreatorCodes", fields: [creatorId], references: [id])
  discountPercent Int      @default(5)
  commissionPercent Int    @default(5)
  usageCount      Int      @default(0)
  totalRevenue    Decimal  @default(0) @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([code])
  @@index([creatorId])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  productId            String
  product              Product  @relation(fields: [productId], references: [id])
  stripeSubscriptionId String   @unique
  status               String   @default("active")
  currentPeriodEnd     DateTime?
  canceledAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([stripeSubscriptionId])
}

// ==================== MODULE: suggestions ====================

model Suggestion {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  status      String   @default("open")
  visibility  String   @default("public")
  upvotes     Int      @default(0)
  authorId  String
  author    User     @relation("Suggestions", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes SuggestionVote[]

  @@index([status])
  @@index([authorId])
}

model SuggestionVote {
  id           String     @id @default(cuid())
  suggestionId String
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("SuggestionVotes", fields: [userId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([suggestionId, userId])
}

// ==================== MODULE: tickets ====================

model TicketDepartment {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets Ticket[]
}

model Ticket {
  id          String         @id @default(cuid())
  subject     String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  closedAt    DateTime?

  departmentId String
  department   TicketDepartment @relation(fields: [departmentId], references: [id])
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  assignedToId String?
  assignedTo   User?            @relation("AssignedTickets", fields: [assignedToId], references: [id])

  messages TicketMessage[]

  @@index([userId])
  @@index([departmentId])
  @@index([status])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_REPLY
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TicketMessage {
  id          String   @id @default(cuid())
  content     String   @db.Text
  isStaffReply Boolean @default(false)
  attachments String[] @default([])
  createdAt   DateTime @default(now())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

model CannedResponse {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== MODULE: vote ====================

model VoteSite {
  id        String    @id @default(cuid())
  name      String
  url       String
  reward    Int       @default(0)
  icon      String?
  isActive  Boolean   @default(true)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  votes     VoteLog[]
}

model VoteLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  voteSiteId String
  voteSite   VoteSite @relation(fields: [voteSiteId], references: [id])
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([voteSiteId])
}

// ==================== MODULE: webhook-logs ====================

model WebhookLog {
  id        String   @id @default(cuid())
  event     String
  url       String
  status    Int?
  response  String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}

// ==================== MODULE: wheel ====================

model WheelPrize {
  id          String  @id @default(cuid())
  name        String
  type        String
  value       Int     @default(0)
  color       String  @default("#3b82f6")
  probability Int     @default(10)
  isActive    Boolean @default(true)
  order       Int     @default(0)
}

model WheelSpin {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("WheelSpins", fields: [userId], references: [id])
  prizeId   String?
  prizeName String
  prizeValue Int     @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
}
