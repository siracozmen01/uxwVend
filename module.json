{
    "id": "store",
    "name": "Store Module",
    "description": "Complete e-commerce functionality with products, categories, cart and orders",
    "version": "1.0.0",
    "author": "uxwVend Team",
    "icon": "ShoppingBag",
    "permissions": [
        "store.view",
        "store.manage"
    ],
    "defaultConfig": {
        "allowGuestCheckout": false,
        "maxCartItems": 10,
        "enableCoupons": true,
        "enableGiftCards": false
    },
    "menu": [
        {
            "label": "Products",
            "path": "/store/products",
            "icon": "Package"
        },
        {
            "label": "Store Categories",
            "path": "/store/categories",
            "icon": "Layers"
        },
        {
            "label": "Orders",
            "path": "/store/orders",
            "icon": "ShoppingCart"
        },
        {
            "label": "Coupons",
            "path": "/store/coupons",
            "icon": "Tag"
        },
        {
            "label": "Store Settings",
            "path": "/settings/goals",
            "icon": "Settings"
        }
    ],
    "routes": [
        {
            "path": "/store",
            "component": "pages/public/page.tsx"
        },
        {
            "path": "/store/cart",
            "component": "pages/public/cart/page.tsx"
        },
        {
            "path": "/store/product/[...params]",
            "component": "pages/public/product/[...params]/page.tsx"
        },
        {
            "path": "/store/order-success",
            "component": "pages/public/order-success/page.tsx"
        },
        {
            "path": "/store/vip",
            "component": "pages/public/vip/page.tsx"
        }
    ],
    "adminRoutes": [
        {
            "path": "/store/products",
            "component": "pages/admin/products/page.tsx"
        },
        {
            "path": "/store/products/new",
            "component": "pages/admin/products/new/page.tsx"
        },
        {
            "path": "/store/products/[id]/edit",
            "component": "pages/admin/products/[id]/edit/page.tsx"
        },
        {
            "path": "/store/categories",
            "component": "pages/admin/categories/page.tsx"
        },
        {
            "path": "/store/orders",
            "component": "pages/admin/orders/page.tsx"
        },
        {
            "path": "/store/orders/[id]",
            "component": "pages/admin/orders/[id]/page.tsx"
        },
        {
            "path": "/store/coupons",
            "component": "pages/admin/coupons/page.tsx"
        },
        {
            "path": "/settings/goals",
            "component": "pages/admin/settings/goals/page.tsx"
        }
    ],
    "api": [
        {
            "path": "/store/cart",
            "handler": "api/cart/route.ts"
        },
        {
            "path": "/store/checkout",
            "handler": "api/checkout/route.ts"
        },
        {
            "path": "/store/categories",
            "handler": "api/categories/route.ts"
        },
        {
            "path": "/store/categories/[id]",
            "handler": "api/categories/[id]/route.ts"
        },
        {
            "path": "/store/products",
            "handler": "api/products/route.ts"
        },
        {
            "path": "/store/products/[id]",
            "handler": "api/products/[id]/route.ts"
        },
        {
            "path": "/store/orders",
            "handler": "api/orders/route.ts"
        },
        {
            "path": "/store/orders/[id]",
            "handler": "api/orders/[id]/route.ts"
        },
        {
            "path": "/store/coupons",
            "handler": "api/coupons/route.ts"
        },
        {
            "path": "/store/coupons/[id]",
            "handler": "api/coupons/[id]/route.ts"
        },
        {
            "path": "/store/coupons/validate",
            "handler": "api/coupons/validate/route.ts"
        },
        {
            "path": "/store/stats",
            "handler": "api/stats/route.ts"
        },
        {
            "path": "/gift-codes",
            "handler": "api/gift-codes/route.ts"
        },
        {
            "path": "/gift-codes/redeem",
            "handler": "api/gift-codes/redeem/route.ts"
        },
        {
            "path": "/creator-codes",
            "handler": "api/creator-codes/route.ts"
        },
        {
            "path": "/bulk-discounts",
            "handler": "api/bulk-discounts/route.ts"
        },
        {
            "path": "/chest",
            "handler": "api/chest/route.ts"
        },
        {
            "path": "/product-commands",
            "handler": "api/product-commands/route.ts"
        },
        {
            "path": "/product-variables",
            "handler": "api/product-variables/route.ts"
        },
        {
            "path": "/widget-stats",
            "handler": "api/widget-stats/route.ts"
        },
        {
            "path": "/chest/[id]",
            "handler": "api/chest/[id]/route.ts"
        },
        {
            "path": "/creator-codes/[id]",
            "handler": "api/creator-codes/[id]/route.ts"
        },
        {
            "path": "/gift-codes/[id]",
            "handler": "api/gift-codes/[id]/route.ts"
        },
        {
            "path": "/community-goal",
            "handler": "api/community-goal/route.ts"
        }
    ],
    "dashboardCards": [
        {
            "id": "revenue",
            "label": "Revenue",
            "icon": "DollarSign",
            "href": "/admin/store/orders",
            "color": "text-green-600",
            "statKey": "revenue"
        },
        {
            "id": "orders",
            "label": "Orders",
            "icon": "ShoppingCart",
            "href": "/admin/store/orders",
            "color": "text-blue-600",
            "statKey": "orders"
        },
        {
            "id": "products",
            "label": "Products",
            "icon": "Package",
            "href": "/admin/store/products",
            "color": "text-purple-600",
            "statKey": "products"
        }
    ],
    "statsApi": "/store/stats",
    "layoutComponents": [
        {
            "id": "LivePurchaseToast",
            "component": "components/LivePurchaseToast"
        }
    ],
    "navbarComponents": [
        {
            "id": "CartIcon",
            "component": "components/CartIcon",
            "order": 20
        }
    ],
    "settingsCards": []
}