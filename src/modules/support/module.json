{
    "id": "support",
    "name": "Support Module",
    "description": "Comprehensive support system including Tickets and Knowledge Base (Help Center)",
    "version": "1.0.0",
    "author": "uxwVend Team",
    "icon": "LifeBuoy",
    "permissions": [
        "support.view",
        "support.manage",
        "tickets.create",
        "tickets.reply"
    ],
    "defaultConfig": {
        "allowAttachments": true,
        "maxAttachmentSize": 10485760,
        "autoCloseAfterDays": 7,
        "enableSearch": true,
        "showViewCount": true,
        "enableFeedback": true
    },
    "menu": [
        {
            "label": "Tickets",
            "path": "/tickets",
            "icon": "Ticket"
        },
        {
            "label": "Help Center",
            "path": "/help",
            "icon": "HelpCircle"
        }
    ],
    "routes": [
        {
            "path": "/support",
            "component": "pages/public/tickets/page.tsx"
        },
        {
            "path": "/support/new",
            "component": "pages/public/tickets/new/page.tsx"
        },
        {
            "path": "/support/[id]",
            "component": "pages/public/tickets/[id]/page.tsx"
        },
        {
            "path": "/help",
            "component": "pages/public/help/page.tsx"
        },
        {
            "path": "/help/[slug]",
            "component": "pages/public/help/[slug]/page.tsx"
        },
        {
            "path": "/help/category/[slug]",
            "component": "pages/public/help/category/[slug]/page.tsx"
        }
    ],
    "adminRoutes": [
        {
            "path": "/tickets",
            "component": "pages/admin/tickets/page.tsx"
        },
        {
            "path": "/tickets/[id]",
            "component": "pages/admin/tickets/[id]/page.tsx"
        },
        {
            "path": "/help",
            "component": "pages/admin/help/page.tsx"
        }
    ],
    "api": [
        {
            "path": "/tickets",
            "handler": "api/tickets/route.ts"
        },
        {
            "path": "/tickets/departments",
            "handler": "api/tickets/departments/route.ts"
        },
        {
            "path": "/tickets/[id]",
            "handler": "api/tickets/[id]/route.ts"
        },
        {
            "path": "/help/articles",
            "handler": "api/help/articles/route.ts"
        },
        {
            "path": "/help/categories",
            "handler": "api/help/categories/route.ts"
        }
    ]
}