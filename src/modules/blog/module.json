{
    "id": "blog",
    "name": "Blog Module",
    "description": "News and announcements system",
    "version": "1.0.0",
    "defaultConfig": {
        "allowComments": true,
        "requireCommentApproval": false,
        "enableRss": true
    },
    "adminRoutes": [
        {
            "path": "/blog/articles",
            "component": "pages/admin/articles/page.tsx"
        },
        {
            "path": "/blog/articles/new",
            "component": "pages/admin/articles/new/page.tsx"
        },
        {
            "path": "/blog/articles/[id]/edit",
            "component": "pages/admin/articles/[id]/edit/page.tsx"
        },
        {
            "path": "/blog/categories",
            "component": "pages/admin/categories/page.tsx"
        }
    ],
    "routes": [
        {
            "path": "/blog",
            "component": "pages/page.tsx"
        },
        {
            "path": "/blog/[...params]",
            "component": "pages/[...params]/page.tsx"
        }
    ],
    "menu": [
        {
            "label": "Articles",
            "path": "/blog/articles",
            "icon": "FileText"
        },
        {
            "label": "Blog Categories",
            "path": "/blog/categories",
            "icon": "FolderOpen"
        }
    ],
    "api": [
        {
            "path": "/blog/articles",
            "handler": "api/articles/route.ts"
        },
        {
            "path": "/blog/articles/[id]",
            "handler": "api/articles/[id]/route.ts"
        },
        {
            "path": "/blog/categories",
            "handler": "api/categories/route.ts"
        },
        {
            "path": "/blog/categories/[id]",
            "handler": "api/categories/[id]/route.ts"
        },
        {
            "path": "/blog/comments",
            "handler": "api/comments/route.ts"
        },
        {
            "path": "/blog/comments/[id]",
            "handler": "api/comments/[id]/route.ts"
        },
        {
            "path": "/blog/stats",
            "handler": "api/stats/route.ts"
        }
    ],
    "dashboardCards": [
        {
            "id": "articles",
            "label": "Articles",
            "icon": "FileText",
            "href": "/admin/blog/articles",
            "color": "text-indigo-600",
            "statKey": "articles"
        }
    ],
    "statsApi": "/blog/stats",
    "homepageSections": [
        {
            "id": "BlogNewsSection",
            "type": "content",
            "component": "components/BlogNewsSection",
            "order": 10
        }
    ]
}