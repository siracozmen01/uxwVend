{
    "id": "announcements",
    "name": "Announcements",
    "description": "Site-wide announcement banners",
    "version": "1.0.0",
    "author": "uxwVend",
    "icon": "Megaphone",
    "permissions": [
        "announcements.manage"
    ],
    "menu": [
        {
            "label": "Announcements",
            "path": "/announcements",
            "icon": "Megaphone"
        }
    ],
    "adminRoutes": [
        {
            "path": "/announcements",
            "component": "pages/admin/page.tsx"
        }
    ],
    "api": [
        {
            "path": "/announcements",
            "handler": "api/route.ts"
        },
        {
            "path": "/announcements/[id]",
            "handler": "api/[id]/route.ts"
        }
    ],
    "layoutComponents": [
        {
            "id": "AnnouncementBanner",
            "component": "components/AnnouncementBanner",
            "exclude": [
                "/admin/*"
            ]
        }
    ]
}