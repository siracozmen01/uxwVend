# uxwVend Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/uxwvend"

# NextAuth
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# OAuth Providers (optional)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Redis (optional, for caching)
REDIS_URL="redis://localhost:6379"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# File Storage (S3-compatible)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="auto"

# Stripe
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PayPal
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"

# Application
NEXT_PUBLIC_APP_NAME="uxwVend"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
