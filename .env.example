# uxwVend Environment Configuration
# Copy this file to .env and fill in your values

# ==================== REQUIRED ====================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/uxwvend"

# Auth Secret (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-key-here"
AUTH_URL="http://localhost:3001"
NEXTAUTH_URL="http://localhost:3001"

# ==================== OPTIONAL ====================

NODE_ENV="development"

# Redis (for rate limiting, caching — falls back to in-memory if not set)
REDIS_URL="redis://localhost:6379"

# OAuth Providers
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe Payments
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PayPal
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"

# Email (Resend - resend.com)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# Game Server (RCON)
RCON_HOST=""
RCON_PORT="25575"
RCON_PASSWORD=""
MC_SERVER_HOST=""
MC_SERVER_PORT="25565"

# Discord Webhooks
DISCORD_WEBHOOK_URL=""

# Cloudflare Turnstile (CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Google Analytics
NEXT_PUBLIC_GA_ID=""

# Punishments API (for external plugin integration)
PUNISHMENTS_API_KEY=""

# Application
NEXT_PUBLIC_APP_NAME="uxwVend"
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_IMAGE_DOMAINS=""
