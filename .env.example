# uxwVend Environment Configuration
# Copy this file to .env and fill in your values.
#
# Module-specific secrets (Stripe, PayPal API keys, RCON, Discord bot token,
# etc.) are configured through Admin Panel > Settings after installing the
# relevant module. Only platform-wide variables live here.

# ============================================================
# REQUIRED
# ============================================================

# PostgreSQL connection string. Append ?connection_limit=20 to raise the
# Prisma pool above the default (num_cpu * 2 + 1) for cluster deployments
# — long-running hooks or big batch jobs can otherwise pin every slot.
DATABASE_URL="postgresql://user:password@localhost:5432/uxwvend"

# Sign JWTs with this. Generate with: openssl rand -base64 32
# Must be identical across every app replica behind the same load balancer.
AUTH_SECRET="your-secret-key-here"

# Canonical URL the platform is served at. Used for OAuth callback URLs
# and password-reset links. AUTH_URL is the Auth.js v5 name; NEXTAUTH_URL
# is kept for backwards compatibility and is checked if AUTH_URL is absent.
AUTH_URL="http://localhost:3001"
NEXTAUTH_URL="http://localhost:3001"

# ============================================================
# PRODUCTION RECOMMENDED
# ============================================================

# Rate limiting + module status cache. REQUIRED when NODE_ENV=production
# AND you run more than one worker (PM2 cluster, multi-pod) — the in-memory
# fallback is process-local and trivially bypassable. Set
# ALLOW_MEMORY_RATE_LIMIT=1 only if you genuinely run a single worker.
# REDIS_URL="redis://localhost:6379"
# ALLOW_MEMORY_RATE_LIMIT=0

# Resend is the current email provider. Leave empty in dev — outbound mail
# degrades to console.log automatically.
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@example.com"

# ============================================================
# OPTIONAL PLATFORM SETTINGS
# ============================================================

NODE_ENV="development"

# Display name + public URL of the site.
NEXT_PUBLIC_APP_NAME="uxwVend"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Comma-separated list of image hostnames allowed through next/image.
# NEXT_PUBLIC_IMAGE_DOMAINS=""

# Override the storage provider. Provider modules register themselves
# (cloudflare-r2, etc.); admin picks the active one from Admin Panel.
# STORAGE_PROVIDER="cloudflare-r2"

# ============================================================
# SECURITY / HARDENING
# ============================================================

# Extra origins accepted by the CSRF proxy guard. AUTH_URL / NEXTAUTH_URL /
# NEXT_PUBLIC_APP_URL are always allowed. Add staging / preview hosts here.
# CSRF_ALLOWED_ORIGINS="https://staging.example.com,https://preview.example.com"

# Shared secret that lets server-to-server callers bypass the CSRF origin
# check by sending `x-internal-request: <secret>`. Leave unset to disable.
# CSRF_INTERNAL_SECRET=""

# Trusted reverse-proxy IPs. When set, forwarded headers (x-forwarded-for)
# are only honored if the direct connection comes from one of these IPs —
# prevents header spoofing when you're NOT behind a trusted proxy.
# TRUSTED_PROXY_IPS="10.0.0.1,10.0.0.2"

# Make the pre-generated OpenAPI spec (/api/v1/openapi) readable without
# admin auth. Off by default so anonymous clients can't enumerate every
# admin endpoint the platform exposes.
# OPENAPI_PUBLIC=0

# Abort any hook listener that takes longer than this many milliseconds so
# a misbehaving module can't hang login / checkout forever.
# HOOK_LISTENER_TIMEOUT_MS=5000

# Max time (ms) the graceful-shutdown handler has to drain before we
# force-exit. Pick lower than your PM2 kill_timeout.
# SHUTDOWN_GRACE_MS=15000

# ============================================================
# PAYPAL GATEWAY (module: paypal-gateway)
# ============================================================
# All three are REQUIRED in production for the PayPal webhook to verify
# signatures. Without them the webhook refuses to run — set
# PAYPAL_ALLOW_UNVERIFIED=1 (dev only!) to bypass.
# PAYPAL_CLIENT_ID=""
# PAYPAL_CLIENT_SECRET=""
# PAYPAL_WEBHOOK_ID=""
# PAYPAL_ENVIRONMENT="sandbox"
# PAYPAL_ALLOW_UNVERIFIED=0

# ============================================================
# OBSERVABILITY
# ============================================================

# Structured-log filter. debug|info|warn|error — defaults to debug in dev,
# info in production.
# LOG_LEVEL="info"

# When set to 1, scripts/postinstall.ts does NOT regenerate the schema,
# theme, and module registries. Useful for Docker layer caching pipelines
# that call the scripts explicitly after npm ci.
# SKIP_POSTINSTALL=0
