# uxwVend Environment Configuration
# Copy this file to .env and fill in your values
#
# NOTE: Module-specific environment variables (Stripe, PayPal, RCON, Discord, etc.)
# are configured through Admin Panel > Settings after installing the relevant modules.
# Only CORE variables are listed here.

# ==================== REQUIRED ====================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/uxwvend"

# Auth Secret (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-key-here"
AUTH_URL="http://localhost:3001"
NEXTAUTH_URL="http://localhost:3001"

# ==================== OPTIONAL ====================

NODE_ENV="development"

# Redis (for rate limiting, caching — falls back to in-memory if not set)
# REDIS_URL="redis://localhost:6379"

# Application
NEXT_PUBLIC_APP_NAME="uxwVend"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Allowed image domains (comma-separated, for next/image optimization)
# NEXT_PUBLIC_IMAGE_DOMAINS=""

# File upload storage provider — set to override the local default
# Provider modules (e.g. cloudflare-r2) register themselves; configure them via Admin Panel
# STORAGE_PROVIDER="cloudflare-r2"
